# XM Cloud Automation Client
SITECORE_CLIENT_ID=your_automation_client_id
SITECORE_CLIENT_SECRET=your_automation_client_secret
SITECORE_AUTHORING_ENDPOINT=https://your-instance.sitecorecloud.io/sitecore/api/authoring/graphql/v1

# Public app URL (local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth0 — MCP OAuth discovery for Sitecore Agentic Studio
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-app.vercel.app
AUTH0_WEB_CLIENT_ID=your_auth0_client_id
AUTH0_WEB_CLIENT_SECRET=your_auth0_client_secret

MCP_BASE_URL=http://localhost:3000
